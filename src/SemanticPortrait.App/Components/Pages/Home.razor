@page "/"
@using SemanticPortrait.App.Services
@using SemanticPortrait.Core
@inject IEmbedder Embedder
@inject SemanticPortrait.Core.LocalEmbedder LocalEmb
@inject ProfileTools Tools
@inject MemoryTools Memory
@inject TaskTools Tasks
@inject Db Database
@inject AnalystSubagent Analyst
@inject ProfileStore Profile
@inject TraceLog Trace
@inject ExportService Export
@inject UsageTracker Usage
@inject Compactor Compaction
@inject KeyVault Vault
@inject HelloKeyStore HelloKeys
@inject WindowsHello Hello
@inject LlmConfig Llm
@inject ProviderRegistry Providers
@inject LMStudioClient LmStudio
@inject NotificationService Notify
@inject ToastActivationService ToastActivation
@inject EmbeddingBackfill Backfill
@inject RecallTools Recall
@inject RecallEngine RecallCore
@inject IntakeTools Intake
@inject SemanticPortrait.Core.Constellation.DbConstellationSource ConstSource
@inject IJSRuntime JS
@implements IDisposable

<div class="sp-app @(_dark ? "theme-dark" : "theme-light") @(_respectMotion ? "sp-rm" : "")">

    @if (_configuring)
    {
        <div class="sp-lock">
            <div class="sp-lock-bg" aria-hidden="true"><span></span><span></span><span></span><span></span></div>
            <div class="sp-lock-card">
                <img class="sp-lock-logo" src="img/logo.png" alt="SemanticPortrait" />
                <h2>Secure your portrait</h2>
                <p class="sp-muted">Your entries are stored only on this device, encrypted. Lock them behind Windows Hello and/or a PIN. (Replies are generated by the AI provider you choose — see the masking option below.)</p>

                @if (_helloAvailable)
                {
                    @if (_cfgHello)
                    {
                        <div class="sp-hello-ok">✓ Windows Hello enabled</div>
                    }
                    else
                    {
                        <button class="sp-hello-btn" @onclick="SetupHello" disabled="@_helloBusy">
                            <span class="sp-hello-glyph">⊞</span>
                            <span>@(_helloBusy ? "Waiting for Windows Hello…" : "Set up Windows Hello")</span>
                        </button>
                    }
                    <div class="sp-lock-divider">and set a recovery PIN</div>
                }
                else
                {
                    <p class="sp-muted">Windows Hello isn't available here — set a PIN.</p>
                }

                <input class="sp-lock-input" type="password" inputmode="numeric" @bind="_cfgPin" @bind:event="oninput"
                       placeholder="PIN (min 6 digits — longer is stronger)" autocomplete="off" />
                <input class="sp-lock-input" type="password" inputmode="numeric" @bind="_cfgPin2" @bind:event="oninput"
                       placeholder="Confirm PIN" autocomplete="off" />
                @if (!string.IsNullOrEmpty(_lockMsg)) { <div class="sp-lock-err">@_lockMsg</div> }

                <label class="sp-mask-consent">
                    <input type="checkbox" @bind="_cfgMask" />
                    <span>
                        <strong>Mask personal details before they leave this device</strong>
                        <small>Names, emails, phone numbers etc. are swapped for placeholders (PERSON_1…)
                        before any text is sent to the AI; the real values stay encrypted on this machine.
                        Recommended. You can change this later in Security.</small>
                    </span>
                </label>

                @* No "set up later": everything in this app sits behind the one central lock. *@
                <div class="sp-lock-actions">
                    <button class="sp-send" @onclick="SaveSetup">Enable lock</button>
                </div>
            </div>
        </div>
    }
    else if (_locked)
    {
        <div class="sp-lock sp-lock-immersive @(_unlocking ? "sp-lock-out" : "")">
            <div class="sp-lock-bg" aria-hidden="true">
                <span></span><span></span><span></span><span></span>
                @LockConstellation
            </div>
            <div class="sp-lock-card">
                <img class="sp-lock-logo" src="img/logo.png" alt="SemanticPortrait" />
                <h2>SemanticPortrait is locked</h2>
                <p class="sp-lock-sub">Unlock your encrypted journal and memory vault.</p>
                @if (HelloKeys.Exists)
                {
                    <button class="sp-hello-btn sp-lock-hello" @onclick="UnlockWithHello" disabled="@_helloBusy">
                        <span class="sp-hello-glyph">⊞</span>
                        <span>@(_helloBusy ? "Waiting for Windows Hello…" : "Sign in with Windows Hello")</span>
                    </button>
                    <div class="sp-lock-divider"><span>or use your PIN</span></div>
                }
                @if (Vault.HasPin)
                {
                    <div class="sp-lock-field">
                        <svg class="sp-lock-ico" viewBox="0 0 24 24" fill="none" aria-hidden="true">
                            <rect x="5" y="11" width="14" height="9" rx="2" stroke="currentColor" stroke-width="1.6"/>
                            <path d="M8 11V8a4 4 0 0 1 8 0v3" stroke="currentColor" stroke-width="1.6"/>
                        </svg>
                        <input class="sp-lock-input" type="password" inputmode="numeric" value="@_pinEntry"
                               @oninput="OnPinInput" @onkeydown="OnPinKey" placeholder="Enter PIN" autocomplete="off" />
                    </div>
                    <button class="sp-lock-unlock" @onclick="UnlockWithPin" disabled="@string.IsNullOrEmpty(_pinEntry)">Unlock</button>
                }
                @if (!string.IsNullOrEmpty(_lockMsg)) { <div class="sp-lock-err">@_lockMsg</div> }
            </div>
        </div>
    }

    @* the top bar yields entirely to the map — its essentials float over the canvas there *@
    @if (!_showConstellation)
    {
    <header class="sp-topbar">
        <div class="sp-brand">
            <span class="sp-mark">✦</span>
            <span class="sp-name">SemanticPortrait</span>
            @{ var who = Profile.Get("name"); }
            @if (!string.IsNullOrWhiteSpace(who))
            {
                <span class="sp-brand-sep">·</span>
                <span class="sp-brand-who">@who</span>
            }
        </div>
        <div class="sp-topbar-right">
            @* mirror of the map's "chat" pill — the two views point at each other the same way *@
            <button class="sp-cf-chat" title="View Constellation"
                    @onclick="ToggleConstellation">✦ map</button>
            @if (_devModeLabel is { } devMode)
            {
                <span class="sp-devmode" title="Which data world this session writes to (DEBUG builds only)">@devMode</span>
            }
            <span class="sp-chip sp-chip-muted">@_provider</span>
            @if (!_hideCosts)
            {
                <span class="sp-chip sp-chip-muted" title="Spend this month (resets monthly)">$@Usage.MonthCostUsd.ToString("0.00")</span>
            }
            <button class="sp-iconbtn sp-bell @(_showNotifs ? "sp-on" : "")" @onclick="ToggleNotifs"
                    title="Notifications">
                🔔
                @if (_unread > 0)
                {
                    <span class="sp-badge">@(_unread > 99 ? "99+" : _unread.ToString())</span>
                }
            </button>
            <button class="sp-iconbtn @(_showMenu ? "sp-on" : "")" @onclick="() => _showMenu = !_showMenu"
                    title="Menu">⋯</button>
        </div>
    </header>
    }

    @if (_showNotifs)
    {
        <div class="sp-menu-scrim" @onclick="() => _showNotifs = false">
            <div class="sp-menu sp-notif-drawer" @onclick:stopPropagation="true">
                <div class="sp-notif-head">
                    <span>Notifications</span>
                    @if (_notifs.Count > 0)
                    {
                        <span class="sp-notif-actions">
                            <button class="sp-iconbtn" title="Mark all read" @onclick="MarkAllRead">✓</button>
                            <button class="sp-iconbtn" title="Clear all" @onclick="ClearNotifs">🗑</button>
                        </span>
                    }
                </div>
                @if (_notifs.Count == 0)
                {
                    <div class="sp-menu-info">Nothing yet. Reminders you set show up here.</div>
                }
                @foreach (var n in _notifs)
                {
                    <div class="sp-notif-item @(n.Read ? "" : "sp-unread")">
                        <button class="sp-notif-main" @onclick="@(() => OpenNotification(n))">
                            <div class="sp-notif-title">@n.Title</div>
                            <div class="sp-notif-body">@n.Body</div>
                            <div class="sp-notif-time">@Friendly(n.CreatedUtc)</div>
                        </button>
                        <button class="sp-notif-x" title="Dismiss"
                                @onclick="@(() => DismissNotif(n))" @onclick:stopPropagation="true">✕</button>
                    </div>
                }
            </div>
        </div>
    }

    @if (_showMenu)
    {
        <div class="sp-menu-scrim" @onclick="() => _showMenu = false">
            <div class="sp-menu" @onclick:stopPropagation="true">
                <button class="sp-menu-item" @onclick="@(async () => { await ToggleConstellation(); _showMenu = false; })">
                    <span>@(_showConstellation ? "💬" : "✦")</span> @(_showConstellation ? "Back to chat" : "View Constellation")
                </button>
                @if (IsDevBuild)
                {
                    <button class="sp-menu-item" title="Wipe the dev sandbox and start a virgin thread (DEBUG only; never touches real data)"
                            @onclick="ResetDevSandbox">
                        <span>🧪</span> Reset sandbox
                    </button>
                }
                <button class="sp-menu-item" @onclick="@(() => { OpenLedger(); _showMenu = false; })">
                    <span>🎯</span> Track record
                </button>
                <button class="sp-menu-item" @onclick="@(() => { _showDev = !_showDev; _showMenu = false; })">
                    <span>🐞</span> Developer trace
                </button>
                <button class="sp-menu-item" @onclick="@(() => { _showTimeline = true; _showMenu = false; })">
                    <span>🕰</span> Timeline
                </button>
                <button class="sp-menu-item" @onclick="@(() => { OpenExport(); _showMenu = false; })">
                    <span>⬇</span> Export…
                </button>
                <button class="sp-menu-item" @onclick="@(() => { _backupMsg = string.Empty; _showBackup = true; _showMenu = false; })">
                    <span>🔐</span> Backup / restore…
                </button>
                <button class="sp-menu-item" @onclick="@(async () => { _showMenu = false; await PickImportFiles(); })">
                    <span>📥</span> Import notes…
                </button>
                <div class="sp-menu-sep"></div>
                <button class="sp-menu-item" @onclick="@(() => { OpenLlm(); _showMenu = false; })">
                    <span>🧠</span> LLM settings
                </button>
                <button class="sp-menu-item" @onclick="@(() => { _embMsg = string.Empty; _showLocalEmb = true; _showMenu = false; })">
                    <span>📦</span> Local embeddings…
                </button>
                <button class="sp-menu-item" @onclick="@(() => { OpenSecurity(); _showMenu = false; })">
                    <span>⚙</span> Security
                </button>
                <button class="sp-menu-item" @onclick="@(() => { LockNow(); _showMenu = false; })">
                    <span>🔒</span> Lock
                </button>
                <button class="sp-menu-item" @onclick="@(() => { ToggleTheme(); _showMenu = false; })">
                    <span>@(_dark ? "☀" : "☾")</span> @(_dark ? "Light mode" : "Dark mode")
                </button>
                <button class="sp-menu-item" @onclick="ToggleHideCosts">
                    <span>@(_hideCosts ? "👁" : "🚫")</span> @(_hideCosts ? "Show costs" : "Hide costs")
                </button>
                <button class="sp-menu-item" @onclick="ToggleStartup">
                    <span>@(_startWithWindows ? "🚀" : "🛑")</span>
                    @(_startWithWindows ? "Starts with Windows" : "Start with Windows: off")
                </button>
                <button class="sp-menu-item" @onclick="ToggleMotion">
                    <span>@(_respectMotion ? "🚶" : "✨")</span>
                    @(_respectMotion ? "Animations: respect OS" : "Animations: always on")
                </button>
                <div class="sp-menu-sep"></div>
                @if (!_hideCosts)
                {
                    <div class="sp-menu-info">@Usage.Summary()</div>
                    <div class="sp-menu-info">@Usage.MonthSummary()</div>
                }
                <div class="sp-menu-info">@EgressSummary()</div>
                <button class="sp-menu-item" @onclick="HideApp">
                    <span>🫥</span> Hide to tray
                </button>
                <button class="sp-menu-item" @onclick="QuitApp">
                    <span>✖</span> Quit
                </button>
                <button class="sp-menu-item sp-menu-danger" @onclick="@(() => { _showReset = true; _showMenu = false; })">
                    <span>🗑</span> Erase all data…
                </button>
            </div>
        </div>
    }

    @if (_showDev)
    {
        <div class="sp-dev">
            <div class="sp-dev-head">
                <span>Dev trace <span class="sp-muted">tool calls · params · thoughts</span></span>
                <span>
                    <button class="sp-iconbtn" @onclick="() => StateHasChanged()" title="Refresh">⟳</button>
                    <button class="sp-iconbtn" @onclick="() => { Trace.Clear(); }" title="Clear">🗑</button>
                    <button class="sp-iconbtn" @onclick="() => _showDev = false" title="Close">✕</button>
                </span>
            </div>
            <div class="sp-dev-body">
                @{ var entries = Trace.Snapshot(); }
                @if (entries.Count == 0)
                {
                    <div class="sp-muted" style="padding:12px;">No trace yet. Send a message.</div>
                }
                @foreach (var e in entries)
                {
                    <div class="sp-trace sp-trace-@e.Source">
                        <div class="sp-trace-top">
                            <span class="sp-trace-tag sp-tag-@e.Kind">@e.Kind</span>
                            <span class="sp-trace-src">@e.Source</span>
                            <span class="sp-trace-name">@e.Name</span>
                            <span class="sp-trace-time">@e.Utc</span>
                        </div>
                        @if (!string.IsNullOrWhiteSpace(e.Detail))
                        {
                            <pre class="sp-trace-detail">@e.Detail</pre>
                        }
                    </div>
                }
            </div>
        </div>
    }

    @if (_showReset)
    {
        <div class="sp-modal-backdrop" @onclick="CloseReset">
            <div class="sp-modal" @onclick:stopPropagation="true">
                <h3>Erase everything?</h3>
                <p class="sp-muted">
                    This permanently deletes your <strong>entire thread</strong>, every note, all
                    embeddings, and your profile from this machine. The thread is meant to be
                    forever — this cannot be undone and there is no backup.
                </p>
                <p>To confirm, type <code>@ResetPhrase</code> below:</p>
                <input class="sp-reset-input" @bind="_resetText" @bind:event="oninput"
                       placeholder="@ResetPhrase" autocomplete="off" />
                <div class="sp-modal-actions">
                    <button class="sp-btn-ghost" @onclick="CloseReset">Cancel</button>
                    <button class="sp-btn-danger" @onclick="WipeEverything"
                            disabled="@(_resetText != ResetPhrase)">Delete everything</button>
                </div>
            </div>
        </div>
    }

    @if (_showImport)
    {
        <div class="sp-modal-backdrop" @onclick="@(() => { if (!_importBusy) _showImport = false; })">
            <div class="sp-modal" @onclick:stopPropagation="true">
                @if (!_importBusy)
                {
                    <h3 style="color:var(--text)">Import @(_importFiles.Count) file(s)</h3>
                    <p class="sp-muted">
                        Each file is distilled by the deep analyst into your model (notes, graph, events) —
                        standardized, deduped against what you already have. Imported content is reference, not chat.
                    </p>
                    <p class="sp-lock-err" style="color:#e0a23d">⚠ This uploads file contents to OpenAI for analysis + embeddings.</p>
                    <div class="sp-ledger">
                        @foreach (var f in _importFiles) { <div class="sp-pred"><div class="sp-pred-claim">@f.FileName</div></div> }
                    </div>
                    <div class="sp-modal-actions">
                        <button class="sp-btn-ghost" @onclick="() => _showImport = false">Cancel</button>
                        <button class="sp-send" @onclick="RunImport">Import</button>
                    </div>
                }
                else
                {
                    <h3 style="color:var(--text)"><span class="sp-spin">✦</span> Importing…</h3>
                    <div class="sp-prog">
                        <div class="sp-prog-bar" style="width:@(_impPct)%"></div>
                    </div>
                    <div class="sp-prog-stat">
                        @if (_impTotal > 0) { <span>~@_impDone / @_impTotal facts</span> } else { <span>scanning…</span> }
                        <span class="sp-muted">@_impPct%</span>
                    </div>
                    @if (!string.IsNullOrWhiteSpace(_impNote)) { <div class="sp-prog-note">@_impNote</div> }
                    <div class="sp-prog-act"><span class="sp-spin-dot"></span> @(_impActivity ?? "working…")</div>
                    <div class="sp-modal-actions">
                        <button class="sp-btn-ghost" @onclick="CancelImport">Stop</button>
                    </div>
                }
            </div>
        </div>
    }

    @if (_showExport)
    {
        <div class="sp-modal-backdrop" @onclick="() => _showExport = false">
            <div class="sp-modal" @onclick:stopPropagation="true" style="width:min(440px,94vw)">
                <h3 style="color:var(--text)">Export</h3>
                <p class="sp-muted">Writes JSON, Markdown, CSV, Mermaid (.mmd) and GraphML to your Desktop.
                    Leave the dates empty for everything.</p>
                <div style="display:flex; gap:8px; align-items:center; margin:6px 0">
                    <label class="sp-muted" style="width:44px">from</label>
                    <input class="sp-lock-input" style="margin:0" type="date" @bind="_expFrom" @bind:event="oninput" />
                </div>
                <div style="display:flex; gap:8px; align-items:center; margin:6px 0">
                    <label class="sp-muted" style="width:44px">to</label>
                    <input class="sp-lock-input" style="margin:0" type="date" @bind="_expTo" @bind:event="oninput" />
                </div>
                <label class="sp-mask-consent" style="margin-top:8px">
                    <input type="checkbox" @bind="_expMasked" />
                    <span><strong>Masked (shareable)</strong>
                    <small>Names, emails and phone numbers are replaced with placeholders. Content can
                    still re-identify you — share thoughtfully.</small></span>
                </label>
                @if (!string.IsNullOrEmpty(_expMsg)) { <div class="sp-lock-err">@_expMsg</div> }
                <div class="sp-modal-actions">
                    <button class="sp-btn-ghost" @onclick="() => _showExport = false">Cancel</button>
                    <button class="sp-send" @onclick="RunExport">Export</button>
                </div>
            </div>
        </div>
    }

    @if (_showBackup)
    {
        <div class="sp-modal-backdrop" @onclick="() => _showBackup = false">
            <div class="sp-modal" @onclick:stopPropagation="true" style="width:min(480px,94vw)">
                <h3 style="color:var(--text)">Backup &amp; restore</h3>
                <p class="sp-muted">A backup is a complete copy of your database — thread, notes, graph,
                    everything — encrypted with your current key. Keep it somewhere safe; it opens only
                    with this vault's PIN.</p>
                <div class="sp-modal-actions" style="justify-content:flex-start">
                    <button class="sp-send" @onclick="RunBackup">Back up now → Desktop</button>
                </div>
                <div class="sp-menu-sep" style="margin:12px 0"></div>
                <p class="sp-muted"><strong>Restore</strong> replaces ALL current data with a backup file.
                    Type <code>RESTORE</code> to arm it.</p>
                <div style="display:flex; gap:8px">
                    <input class="sp-lock-input" style="margin:0" placeholder="type RESTORE"
                           @bind="_restoreConfirm" @bind:event="oninput" autocomplete="off" />
                    <button class="sp-btn-ghost" disabled="@(_restoreConfirm != "RESTORE")"
                            @onclick="PickAndRestoreBackup">Choose file…</button>
                </div>
                @if (!string.IsNullOrEmpty(_backupMsg)) { <div class="sp-muted" style="margin-top:8px">@_backupMsg</div> }
                <div class="sp-modal-actions">
                    <button class="sp-btn-ghost" @onclick="() => _showBackup = false">Done</button>
                </div>
            </div>
        </div>
    }

    @if (_showTimeline)
    {
        <div class="sp-modal-backdrop" @onclick="() => _showTimeline = false">
            <div class="sp-modal" @onclick:stopPropagation="true" style="width:min(560px,94vw); max-height:80vh; overflow:auto">
                <h3 style="color:var(--text)">Timeline</h3>
                @{
                    var tlItems = new List<(DateTime Utc, string Icon, string Text)>();
                    if (Database.IsOpen)
                    {
                        foreach (var ev in Database.GetEvents())
                            if (DateTime.TryParse(ev.EventUtc, null, System.Globalization.DateTimeStyles.RoundtripKind, out var eu))
                                tlItems.Add((eu.ToUniversalTime(), "📅", ev.Summary));
                        foreach (var m in Database.GetMessages())
                            if (m.Role == "user" && DateTime.TryParse(m.CreatedUtc, null, System.Globalization.DateTimeStyles.RoundtripKind, out var mu))
                                tlItems.Add((mu.ToUniversalTime(), "✍", m.Text.Length > 120 ? m.Text[..120] + "…" : m.Text));
                    }
                    var tlDays = tlItems.OrderByDescending(x => x.Utc)
                        .GroupBy(x => x.Utc.ToLocalTime().Date).ToList();
                }
                @if (tlDays.Count == 0)
                {
                    <p class="sp-muted">Nothing yet — entries and dated events will appear here.</p>
                }
                @foreach (var day in tlDays)
                {
                    <p style="color:var(--accent); margin:12px 0 4px; font-weight:600">@day.Key.ToString("dddd, MMM d yyyy")</p>
                    @foreach (var it in day)
                    {
                        <div style="display:flex; gap:8px; margin:3px 0">
                            <span>@it.Icon</span>
                            <span class="sp-muted" style="min-width:52px">@it.Utc.ToLocalTime().ToString("h:mm tt")</span>
                            <span style="color:var(--text)">@it.Text</span>
                        </div>
                    }
                }
                <div class="sp-modal-actions">
                    <button class="sp-btn-ghost" @onclick="() => _showTimeline = false">Done</button>
                </div>
            </div>
        </div>
    }

    @if (_showLocalEmb)
    {
        <div class="sp-modal-backdrop" @onclick="() => { if (!_embBusy) _showLocalEmb = false; }">
            <div class="sp-modal" @onclick:stopPropagation="true" style="width:min(460px,94vw)">
                <h3 style="color:var(--text)">Local embeddings</h3>
                @if (LocalEmb.IsAvailable)
                {
                    <p class="sp-muted">✓ Installed — semantic recall runs 100% on this machine.
                        Nothing is sent to OpenAI for embeddings and it costs nothing.</p>
                }
                else
                {
                    <p class="sp-muted">Semantic recall currently uses OpenAI embeddings (your text
                        leaves the machine, masked if masking is on). Installing the local model
                        (all-MiniLM-L6-v2, ~90 MB, downloaded once from huggingface.co) moves recall
                        fully on-device and re-embeds your existing data locally.</p>
                }
                @if (!string.IsNullOrEmpty(_embMsg)) { <div class="sp-muted" style="margin-top:8px">@_embMsg</div> }
                <div class="sp-modal-actions">
                    <button class="sp-btn-ghost" disabled="@_embBusy" @onclick="() => _showLocalEmb = false">Done</button>
                    @if (!LocalEmb.IsAvailable)
                    {
                        <button class="sp-send" disabled="@_embBusy" @onclick="DownloadLocalModelAsync">
                            @(_embBusy ? "working…" : "Download & switch")
                        </button>
                    }
                </div>
            </div>
        </div>
    }

    @if (_showLedger)
    {
        <div class="sp-modal-backdrop" @onclick="() => _showLedger = false">
            <div class="sp-modal" @onclick:stopPropagation="true" style="width:min(560px,94vw)">
                <h3 style="color:var(--text)">Calibration — track record</h3>
                @{
                    var preds = Database.IsOpen ? Database.GetPredictions() : new List<Prediction>();
                    var resolved = preds.Where(p => p.Score is not null).ToList();
                    var acc = resolved.Count > 0 ? resolved.Average(p => p.Score!.Value) : 0;
                }
                @if (resolved.Count > 0)
                {
                    <p class="sp-muted">Accuracy over @resolved.Count resolved: <strong style="color:var(--accent)">@((acc*100).ToString("0"))%</strong></p>
                }
                @if (preds.Count == 0)
                {
                    <p class="sp-muted">No predictions yet. When you forecast something, the analyst logs a falsifiable prediction and scores it later.</p>
                }
                <div class="sp-ledger">
                    @foreach (var p in preds)
                    {
                        <div class="sp-pred @(p.ResolvedUtc is null ? "open" : "done")">
                            <div class="sp-pred-claim">@p.Claim</div>
                            <div class="sp-pred-crit sp-muted">resolves: @p.Criterion</div>
                            @if (p.ResolvedUtc is not null)
                            {
                                <div class="sp-pred-out">→ @p.Outcome <span class="sp-pred-score">@(((p.Score ?? 0)*100).ToString("0"))%</span></div>
                            }
                            else
                            {
                                <div class="sp-pred-open sp-muted">open</div>
                            }
                        </div>
                    }
                </div>
                <div class="sp-modal-actions">
                    <button class="sp-btn-ghost" @onclick="() => _showLedger = false">Done</button>
                </div>
            </div>
        </div>
    }

    @if (_showLlm)
    {
        <div class="sp-modal-backdrop" @onclick="CloseLlm">
            <div class="sp-modal sp-llm-modal" @onclick:stopPropagation="true">
                <h3 style="color:var(--text)">LLM settings</h3>
                <p class="sp-muted" style="margin:0 0 14px; font-size:13px;">
                    Choose your inference provider and model, see pricing, and store your API key.
                    Keys are saved encrypted on this device.
                </p>

                <div class="sp-llm-layout">
                    <!-- provider rail -->
                    <div class="sp-llm-rail">
                        @foreach (var p in ModelCatalog.Providers)
                        {
                            <button class="sp-llm-prov @(p.Id == _llmProvider ? "sp-on" : "")"
                                    @onclick="() => SelectLlmProvider(p.Id)">
                                <span class="sp-llm-prov-name">@p.Name</span>
                                <span class="sp-llm-prov-tags">
                                    @if (Llm.HasKey(p.Id)) { <span class="sp-llm-pill ok">key</span> }
                                    @if (!p.Connected) { <span class="sp-llm-pill soon">soon</span> }
                                </span>
                            </button>
                        }
                    </div>

                    <!-- detail panel for the selected provider -->
                    @{ var prov = ModelCatalog.Find(_llmProvider)!; }
                    <div class="sp-llm-detail">
                        <div class="sp-llm-row-head">
                            <span class="sp-llm-title">@prov.Name</span>
                            @if (!prov.Connected)
                            {
                                <span class="sp-llm-pill soon">not yet connected</span>
                            }
                            else if (_llmProvider == Providers.Active.ProviderId)
                            {
                                <span class="sp-llm-pill active">active</span>
                            }
                            else
                            {
                                <button class="sp-llm-use" @onclick="() => UseLlmProvider(_llmProvider)">Use this provider</button>
                            }
                        </div>

                        @if (prov.Local)
                        {
                            <div class="sp-llm-local-note">
                                🛡️ Runs entirely on your machine via LM Studio's local server.
                                Nothing leaves this device — <b>100% offline</b>, free.
                            </div>

                            <label class="sp-llm-label">Server URL</label>
                            <div class="sp-llm-key">
                                <input class="sp-reset-input" style="margin:0;" type="text"
                                       placeholder="http://localhost:1234/v1" @bind="_llmUrl" @bind:event="oninput" autocomplete="off" />
                                <button class="sp-send" @onclick="SaveLlmUrl">Save</button>
                            </div>
                            <div class="sp-llm-keyhint">
                                <button class="sp-btn-ghost" @onclick="DetectLmModels" disabled="@_llmDetecting">
                                    @(_llmDetecting ? "Checking…" : "Detect models")
                                </button>
                                @if (_llmReachable == true) { <span class="sp-llm-pill ok">reachable</span> }
                                else if (_llmReachable == false) { <span class="sp-llm-pill soon">no response</span> }
                            </div>

                            <label class="sp-llm-label">Model</label>
                            @if (_llmDetected.Count > 0)
                            {
                                <div class="sp-llm-models">
                                    @foreach (var id in _llmDetected)
                                    {
                                        <button class="sp-llm-model @(id == _llmModel ? "sp-on" : "")"
                                                @onclick="() => SelectLlmModel(id)">
                                            <span class="sp-llm-model-name">@id</span>
                                        </button>
                                    }
                                </div>
                            }
                            <div class="sp-llm-key" style="margin-top:6px;">
                                <input class="sp-reset-input" style="margin:0;" type="text"
                                       placeholder="model id loaded in LM Studio" @bind="_llmModel" @bind:event="oninput" autocomplete="off" />
                                <button class="sp-send" @onclick="SaveLlmModel" disabled="@string.IsNullOrWhiteSpace(_llmModel)">Set</button>
                            </div>
                            <div class="sp-llm-keyhint sp-muted">
                                Load a model in LM Studio and start its server (Developer → Start server).
                                Memory search still uses your OpenAI embeddings unless disabled.
                            </div>
                        }
                        else
                        {
                            <label class="sp-llm-label">Model</label>
                            <div class="sp-llm-models">
                                @foreach (var m in prov.Models)
                                {
                                    <button class="sp-llm-model @(m.Id == _llmModel ? "sp-on" : "")"
                                            @onclick="() => SelectLlmModel(m.Id)">
                                        <span class="sp-llm-model-name">@m.Name</span>
                                        @if (!string.IsNullOrEmpty(m.Note)) { <span class="sp-llm-model-note">@m.Note</span> }
                                    </button>
                                }
                            </div>

                            <label class="sp-llm-label">Pricing <span class="sp-muted">(USD / 1M tokens)</span></label>
                            <div class="sp-llm-prices">
                                <div><span>Input</span><b>@Price(CurrentLlmModel().Pricing?.InputPerM)</b></div>
                                <div><span>Cached in</span><b>@Price(CurrentLlmModel().Pricing?.CachedInputPerM)</b></div>
                                <div><span>Output</span><b>@Price(CurrentLlmModel().Pricing?.OutputPerM)</b></div>
                            </div>

                            <label class="sp-llm-label">API key</label>
                            <div class="sp-llm-key">
                                <input class="sp-reset-input" style="margin:0;" type="password"
                                       placeholder="@prov.KeyHint" @bind="_llmKey" @bind:event="oninput" autocomplete="off" />
                                <button class="sp-send" @onclick="SaveLlmKey" disabled="@string.IsNullOrWhiteSpace(_llmKey)">Save</button>
                                @if (Llm.HasStoredKey(_llmProvider))
                                {
                                    <button class="sp-btn-ghost" @onclick="ClearLlmKey">Remove</button>
                                }
                            </div>
                            <div class="sp-llm-keyhint">
                                @if (Llm.HasStoredKey(_llmProvider)) { <span class="sp-llm-pill ok">stored key in use</span> }
                                else if (Llm.HasKey(_llmProvider)) { <span class="sp-muted">using key from .env</span> }
                                else { <span class="sp-muted">no key yet — </span><a href="@prov.SignupUrl" target="_blank">get one</a> }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_llmMsg)) { <div class="sp-llm-saved">@_llmMsg</div> }
                    </div>
                </div>

                <div class="sp-modal-actions" style="margin-top:16px;">
                    <button class="sp-btn-ghost" @onclick="CloseLlm">Done</button>
                </div>
            </div>
        </div>
    }

    @if (_showSecurity)
    {
        <div class="sp-modal-backdrop" @onclick="() => _showSecurity = false">
            <div class="sp-modal" @onclick:stopPropagation="true">
                <h3 style="color:var(--text)">Security</h3>

                <label class="sp-mask-consent" style="margin-bottom:14px;">
                    <input type="checkbox" checked="@_maskOn" @onchange="ToggleMasking" />
                    <span>
                        <strong>Mask personal details before sending to the AI</strong>
                        <small>Names/emails/phones → placeholders; real values stay encrypted on this device.</small>
                    </span>
                </label>

                <p class="sp-muted">Change your PIN (re-wraps the same encryption key — your data is kept).</p>
                <input class="sp-reset-input" type="password" inputmode="numeric" @bind="_newPin" @bind:event="oninput"
                       placeholder="New PIN (min 4 digits)" autocomplete="off" />
                <input class="sp-reset-input" type="password" inputmode="numeric" @bind="_newPin2" @bind:event="oninput"
                       placeholder="Confirm new PIN" autocomplete="off" />
                <button class="sp-send" @onclick="ChangePin">Update PIN</button>

                @if (_helloAvailable)
                {
                    <p class="sp-muted" style="margin-top:14px;">Windows Hello</p>
                    <button class="sp-hello-btn" @onclick="ReenrollHello" disabled="@_helloBusy">
                        <span class="sp-hello-glyph">⊞</span>
                        <span>@(_helloBusy ? "Waiting for Windows Hello…" : (HelloKeys.Exists ? "Re-enroll Windows Hello" : "Enable Windows Hello"))</span>
                    </button>
                    @if (HelloKeys.Exists)
                    {
                        <button class="sp-btn-ghost" @onclick="RemoveHello">Remove Windows Hello</button>
                    }
                }

                @if (!string.IsNullOrEmpty(_secMsg)) { <div class="sp-lock-err" style="color:#28e070">@_secMsg</div> }

                <div class="sp-modal-actions">
                    <button class="sp-btn-ghost" @onclick="() => _showSecurity = false">Done</button>
                </div>
            </div>
        </div>
    }

    <div class="sp-body solo">

      @if (!_showConstellation)
      {
        <!-- CHAT VIEW -->
        <section class="sp-chat">
            <div class="sp-messages" @ref="_messagesEl"
                 @oncontextmenu="OnChatContextMenu" @oncontextmenu:preventDefault="true">
              <div class="sp-thread">
                @if (_clearedBefore > 0)
                {
                    <button class="sp-cleared-note" @onclick="UnclearChatView" title="Show earlier messages">
                        ✦ view cleared — @Math.Min(_clearedBefore, _messages.Count) earlier messages tucked away · tap to bring them back
                    </button>
                }
                @for (var mi = Math.Min(_clearedBefore, _messages.Count); mi < _messages.Count; mi++)
                {
                    var m = _messages[mi];
                    @if (m.Role == "tool")
                    {
                        @* Consecutive tool calls fold into ONE collapsible folder (a long analyst
                           run was drowning the chat in stacked bubbles). Collapsed = a single
                           count line; expanded = chips wrapping HORIZONTALLY, each click-to-inspect.
                           The first message of the run carries the folder's open/closed state. *@
                        var group = new List<Msg>();
                        while (mi < _messages.Count && _messages[mi].Role == "tool") { group.Add(_messages[mi]); mi++; }
                        mi--;
                        var head = group[0];
                        var isAnalyst = group.Any(g => g.Text.StartsWith("🧠"));
                        @if (group.Count == 1)
                        {
                            <div class="sp-msg sp-msg-tool">
                                <div class="sp-bubble sp-tool-bubble @(head.Expanded ? "open" : "")"
                                     @onclick="() => head.Expanded = !head.Expanded" title="Click to inspect">
                                    <span>@head.Text</span>
                                    @if (!string.IsNullOrEmpty(head.Detail))
                                    {
                                        <span class="sp-tool-caret">@(head.Expanded ? "▾" : "▸")</span>
                                    }
                                    @if (head.Expanded && !string.IsNullOrEmpty(head.Detail))
                                    {
                                        <pre class="sp-tool-detail">@head.Detail</pre>
                                    }
                                </div>
                            </div>
                        }
                        else
                        {
                            var selected = group.FirstOrDefault(g => g.Expanded);
                            <div class="sp-msg sp-msg-tool">
                                <div class="sp-tool-folder @(head.FolderOpen ? "open" : "")">
                                    <div class="sp-tool-folder-head" @onclick="() => head.FolderOpen = !head.FolderOpen"
                                         title="Click to see what happened in the background">
                                        <span>@(isAnalyst ? "🧠 background analysis" : "🔧 tools") · @group.Count steps</span>
                                        <span class="sp-tool-caret">@(head.FolderOpen ? "▾" : "▸")</span>
                                    </div>
                                    @if (head.FolderOpen)
                                    {
                                        <div class="sp-tool-chips">
                                            @foreach (var t in group)
                                            {
                                                var chip = t;   // capture for the lambda
                                                <span class="sp-tool-chip @(chip.Expanded ? "open" : "")"
                                                      @onclick="() => SelectChip(group, chip)">@chip.Text</span>
                                            }
                                        </div>
                                        @if (selected is not null && !string.IsNullOrEmpty(selected.Detail))
                                        {
                                            <pre class="sp-tool-detail"><b>@selected.Text</b>
@selected.Detail</pre>
                                        }
                                    }
                                </div>
                            </div>
                        }
                    }
                    else if (m.Role == "sys")
                    {
                        <div class="sp-msg sp-msg-sys"><div class="sp-bubble">@Md(m.Text)</div></div>
                    }
                    else
                    {
                        <div class="sp-msg sp-msg-@m.Role">
                            @if (m.Role == "ai")
                            {
                                <img class="sp-avatar" src="img/logo.png" alt="SemanticPortrait" />
                            }
                            <div class="sp-col">
                                @if (m.Role == "user")
                                {
                                    <div class="sp-bubble">@m.Text</div>
                                }
                                else if (m.Streaming && string.IsNullOrEmpty(m.Text))
                                {
                                    @* waiting for the first token: typing dots inside the bubble *@
                                    <div class="sp-bubble sp-streaming">
                                        <span class="sp-typing"><span></span><span></span><span></span></span>
                                    </div>
                                }
                                else
                                {
                                    @* sp-streaming paints a live caret at the end of the text via CSS *@
                                    <div class="sp-bubble @(m.Streaming ? "sp-streaming" : "")">@Md(m.Text)</div>
                                }
                                @if (m.Sourced)
                                {
                                    <div class="sp-sourced">✓ Sourced from your journal</div>
                                }
                                <div class="sp-time">@m.Time</div>
                            </div>
                        </div>
                    }
                }
              </div>
            </div>
            @* right-click menu: view-only clear (nothing is deleted) *@
            @if (_chatCtx is { } cm)
            {
                <div class="sp-menu-scrim" @onclick="() => _chatCtx = null"
                     @oncontextmenu="() => _chatCtx = null" @oncontextmenu:preventDefault="true"></div>
                <div class="sp-ctxmenu" style="left:min(@(cm.X)px, calc(100vw - 240px)); top:min(@(cm.Y)px, calc(100vh - 110px))">
                    <button class="sp-menu-item" @onclick="ClearChatView">
                        <span>🧹</span> Clear chat view
                    </button>
                    @if (_clearedBefore > 0)
                    {
                        <button class="sp-menu-item" @onclick="UnclearChatView">
                            <span>↺</span> Show earlier messages
                        </button>
                    }
                </div>
            }
            <div class="sp-composer-wrap">
                <div class="sp-composer">
                    <textarea @ref="_input" @bind="_draft" @bind:event="oninput"
                              @onkeydown="OnKey" disabled="@_busy"
                              placeholder="Write a message…" rows="1"></textarea>
                    <button class="sp-send-circle" @onclick="Send"
                            disabled="@(_busy || string.IsNullOrWhiteSpace(_draft))" title="Send">
                        @(_busy ? "…" : "↑")
                    </button>
                </div>
            </div>
        </section>
      }
      else
      {
        <!-- CONSTELLATION VIEW (full screen) -->
        <section class="sp-constellation">
            <div class="sp-const-canvas">
                @if (_sigilMode && !_ambient)
                {
                    @* not rendered while ambient — two live turbulence-filter instances is
                       exactly the load that freezes the webview *@
                    <SemanticPortrait.App.Components.Constellation.SigilView P="_sigil" />
                }
                else
                {
                    <SemanticPortrait.App.Components.Constellation.ConstellationView
                        Model="_constModel" OnReject="RejectFromConstellation" OnAsk="AskAboutNode"
                        Stats="_sigil?.Sig" MemorySpan="@_memorySpan"
                        Narrate="@(id => RecallCore.NarrateNodeAsync(id))" />
                }

                @* floating chrome: the canvas is the page; the essentials hover over it *@
                <div class="sp-const-float sp-cf-left">
                    <button class="sp-cf-chat" title="Back to chat" @onclick="ToggleConstellation">💬 chat</button>
                    <div class="sp-cf-title">
                        <b>Constellation</b>
                        @if (_memoryCount > 0) { <span>a living map of you · @_memoryCount memories</span> }
                    </div>
                    @if (_devModeLabel is { } devMode2)
                    {
                        <span class="sp-devmode" title="Which data world this session writes to (DEBUG builds only)">@devMode2</span>
                    }
                </div>
                <div class="sp-const-float sp-cf-right">
                    <button class="sp-cf-btn" title="Rebuild the map from all known facts"
                            disabled="@(_rebuildState == RState.Running)" @onclick="() => _showRebuildConfirm = true">
                        @(_rebuildState == RState.Running ? "✦ blooming…" : "⟳ rebuild")
                    </button>
                    <button class="sp-cf-btn" title="Toggle sample design vs your live data" @onclick="ToggleConstSample">
                        @(_constSample ? "● sample" : "● live")
                    </button>
                    <button class="sp-cf-btn" title="Observatory = your private, labeled map. Sigil = the masked public artwork — aggregates only, shareable."
                            @onclick="ToggleSigilMode">
                        @(_sigilMode ? "✸ sigil" : "✦ observatory")
                    </button>
                    <button class="sp-cf-btn" title="Scrub back through time — the portrait as it was"
                            @onclick="ToggleScrub">⏳ @(_scrubActive ? ScrubLabel : "time")</button>
                    @if (_sigilMode)
                    {
                        <button class="sp-cf-btn" title="Fullscreen, living" @onclick="ToggleAmbient">◱ ambient</button>
                    }
                    <button class="sp-cf-btn" title="Menu" @onclick="() => _showMenu = !_showMenu">⋯</button>
                </div>

                @if (_scrubActive)
                {
                    <div class="sp-scrub">
                        <span class="sp-scrub-from">@_scrubFromUtc.ToLocalTime().ToString("MMM d")</span>
                        <input type="range" min="0" max="100" step="0.5" value="@_scrubPos" @oninput="OnScrub" />
                        <span class="sp-scrub-at">@ScrubLabel</span>
                    </div>
                }

                @if (_rebuildState != RState.Idle)
                {
                    <div class="sp-ro">
                        <div class="sp-ro-card" @onclick:stopPropagation="true">
                            @if (_rebuildState == RState.Running)
                            {
                                <div class="sp-ro-orb"></div>
                                <div class="sp-ro-title">✦ Rebuilding your constellation…</div>
                                <div class="sp-ro-status">@_rebuildStatus</div>
                                <div class="sp-ro-meter">@_rebuildCount updates · $@RebuildCost.ToString("0.000") · @RebuildTokens.ToString("N0") tokens</div>
                                <div class="sp-ro-actions">
                                    <button class="sp-btn-ghost" @onclick="CancelRebuild">Cancel</button>
                                </div>
                            }
                            else if (_rebuildState == RState.Empty)
                            {
                                <div class="sp-ro-title">Nothing to map yet</div>
                                <div class="sp-ro-status">Your constellation grows from what you write. Spend a week
                                    journaling with the app, then rebuild to watch it bloom. (Or preview the design now.)</div>
                                <div class="sp-ro-actions">
                                    <button class="sp-btn-ghost" @onclick="@(() => { _rebuildState = RState.Idle; if (!_constSample) ToggleConstSample(); })">Preview sample</button>
                                    <button class="sp-send" @onclick="() => _rebuildState = RState.Idle">Got it</button>
                                </div>
                            }
                            else  @* Cancelled *@
                            {
                                <div class="sp-ro-title">Paused</div>
                                <div class="sp-ro-status">@_rebuildStatus</div>
                                <div class="sp-ro-meter">@_rebuildCount updates · $@RebuildCost.ToString("0.000") · @RebuildTokens.ToString("N0") tokens</div>
                                <div class="sp-ro-actions">
                                    <button class="sp-btn-ghost" @onclick="() => _rebuildState = RState.Idle">Done</button>
                                    <button class="sp-btn-ghost" @onclick="() => RunRebuild(restart: true)">Restart</button>
                                    <button class="sp-send" @onclick="() => RunRebuild(restart: false)">Continue</button>
                                </div>
                            }
                        </div>
                    </div>
                }
            </div>
        </section>
      }
    </div>

    @* farewell screen — Quit shows it for a beat before the process exits *@
    @if (_quitting)
    {
        <div class="sp-quit" aria-hidden="true"></div>
    }

    @* dev error toasts — float above every view (chat, constellation, ambient) *@
    @if (_devToasts.Count > 0)
    {
        <div class="sp-devtoasts">
            @foreach (var t in _devToasts.ToList())
            {
                <div class="sp-devtoast" title="@t.Detail" @onclick="() => DismissDevToast(t)">
                    <span class="sp-devtoast-src">⚠ @t.Source</span>
                    <span class="sp-devtoast-msg">@t.Message</span>
                    <span class="sp-devtoast-x">✕</span>
                </div>
            }
        </div>
    }

    @if (_ambient && _sigilMode)
    {
        @* Exit is EVERYWHERE: click anywhere, Escape, or the ✕ — a fullscreen mode without an
           obvious way out reads as a crash. *@
        <div class="sp-ambient" tabindex="0" @onclick="ToggleAmbient"
             @onkeydown="@(e => { if (e.Key == "Escape") ToggleAmbient(); })">
            <SemanticPortrait.App.Components.Constellation.SigilView P="_sigil" />
            @* stopPropagation: the click would bubble to the overlay's own exit handler and
               toggle ambient TWICE — a one-click no-op that reads as a dead button *@
            <button class="sp-ambient-exit" title="Exit ambient"
                    @onclick="ToggleAmbient" @onclick:stopPropagation="true">✕ exit</button>
            <div class="sp-ambient-hint">click anywhere to exit</div>
        </div>
    }

    @if (_showRebuildConfirm)
    {
        <div class="sp-modal-backdrop" @onclick="() => _showRebuildConfirm = false">
            <div class="sp-modal" @onclick:stopPropagation="true">
                <h3 style="color:var(--accent)">Rebuild your constellation?</h3>
                <p>A clean-room analyst will re-read your notes, events and entries and regenerate the
                   map from scratch — you'll watch it bloom in. Existing nodes are refined, not wiped.
                   This re-runs analysis (uses tokens).</p>
                <div class="sp-modal-actions">
                    <button class="sp-btn-ghost" @onclick="() => _showRebuildConfirm = false">Cancel</button>
                    <button class="sp-send" @onclick="() => RunRebuild(restart: false)">✦ Rebuild</button>
                </div>
            </div>
        </div>
    }
</div>

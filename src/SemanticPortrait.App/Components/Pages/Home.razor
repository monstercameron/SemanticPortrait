    @if (_showLlm)
    {
        <div class="sp-modal-backdrop" @onclick="CloseLlm">
            <div class="sp-modal sp-llm-modal" @onclick:stopPropagation="true">
                <h3>@L["Llm.Title"]</h3>
                <p class="sp-muted" style="margin:0 0 14px; font-size:13px;">
                    @L["Llm.Blurb"]
                </p>

                <div class="sp-llm-layout">
                    <!-- provider rail -->
                    <div class="sp-llm-rail">
                        @foreach (var p in ModelCatalog.Providers)
                        {
                            <button class="sp-llm-prov @(p.Id == _llmProvider ? "sp-on" : "")"
                                    @onclick="() => SelectLlmProvider(p.Id)">
                                <span class="sp-llm-prov-name">@p.Name</span>
                                <span class="sp-llm-prov-tags">
                                    @if (Llm.HasKey(p.Id)) { <span class="sp-llm-pill ok">@L["Llm.KeyPill"]</span> }
                                    @if (!p.Connected) { <span class="sp-llm-pill soon">@L["Llm.SoonPill"]</span> }
                                </span>
                            </button>
                        }
                    </div>

                    <!-- detail panel for the selected provider -->
                    @{ var prov = ModelCatalog.Find(_llmProvider)!; }
                    <div class="sp-llm-detail">
                        <div class="sp-llm-row-head">
                            <span class="sp-llm-title">@prov.Name</span>
                            @if (!prov.Connected)
                            {
                                <span class="sp-llm-pill soon">@L["Llm.NotConnectedPill"]</span>
                            }
                            else if (_llmProvider == Providers.Active.ProviderId)
                            {
                                <span class="sp-llm-pill active">@L["Llm.ActivePill"]</span>
                            }
                            else
                            {
                                <button class="sp-llm-use" @onclick="() => UseLlmProvider(_llmProvider)">@L["Llm.UseProviderButton"]</button>
                            }
                        </div>

                        @if (prov.Local)
                        {
                            <div class="sp-llm-local-note">
                                🛡️ @((MarkupString)L["Llm.LocalNote"].Value)
                            </div>

                            <label class="sp-llm-label">@L["Llm.ServerUrlLabel"]</label>
                            <div class="sp-llm-key">
                                <input class="sp-reset-input" style="margin:0;" type="text"
                                       placeholder="@L["Llm.ServerUrlPlaceholder"]" @bind="_llmUrl" @bind:event="oninput" autocomplete="off" />
                                <button class="sp-send" @onclick="SaveLlmUrl">@L["Llm.SaveButton"]</button>
                            </div>
                            <div class="sp-llm-keyhint">
                                <button class="sp-btn-ghost" @onclick="DetectLmModels" disabled="@_llmDetecting">
                                    @(_llmDetecting ? L["Llm.CheckingButton"] : L["Llm.DetectModelsButton"])
                                </button>
                                @if (_llmReachable == true) { <span class="sp-llm-pill ok">@L["Llm.ReachablePill"]</span> }
                                else if (_llmReachable == false) { <span class="sp-llm-pill soon">@L["Llm.NoResponsePill"]</span> }
                            </div>

                            <label class="sp-llm-label">@L["Llm.ModelLabel"]</label>
                            @if (_llmDetected.Count > 0)
                            {
                                <div class="sp-llm-models">
                                    @foreach (var id in _llmDetected)
                                    {
                                        <button class="sp-llm-model @(id == _llmModel ? "sp-on" : "")"
                                                @onclick="() => SelectLlmModel(id)">
                                            <span class="sp-llm-model-name">@id</span>
                                        </button>
                                    }
                                </div>
                            }
                            <div class="sp-llm-key" style="margin-top:6px;">
                                <input class="sp-reset-input" style="margin:0;" type="text"
                                       placeholder="@L["Llm.ModelIdPlaceholder"]" @bind="_llmModel" @bind:event="oninput" autocomplete="off" />
                                <button class="sp-send" @onclick="SaveLlmModel" disabled="@string.IsNullOrWhiteSpace(_llmModel)">@L["Llm.SetButton"]</button>
                            </div>
                            <div class="sp-llm-keyhint sp-muted">
                                @L["Llm.LocalHint"]
                            </div>
                        }
                        else
                        {
                            <label class="sp-llm-label">@L["Llm.ModelLabel"]</label>
                            <div class="sp-llm-models">
                                @foreach (var m in prov.Models)
                                {
                                    <button class="sp-llm-model @(m.Id == _llmModel ? "sp-on" : "")"
                                            @onclick="() => SelectLlmModel(m.Id)">
                                        <span class="sp-llm-model-name">@m.Name</span>
                                        @if (!string.IsNullOrEmpty(m.Note)) { <span class="sp-llm-model-note">@m.Note</span> }
                                    </button>
                                }
                            </div>

                            <label class="sp-llm-label">@L["Llm.PricingLabel"] <span class="sp-muted">@L["Llm.PricingUnit"]</span></label>
                            <div class="sp-llm-prices">
                                <div><span>@L["Llm.PriceInput"]</span><b>@Price(CurrentLlmModel().Pricing?.InputPerM)</b></div>
                                <div><span>@L["Llm.PriceCachedIn"]</span><b>@Price(CurrentLlmModel().Pricing?.CachedInputPerM)</b></div>
                                <div><span>@L["Llm.PriceOutput"]</span><b>@Price(CurrentLlmModel().Pricing?.OutputPerM)</b></div>
                            </div>

                            <label class="sp-llm-label">@L["Llm.ApiKeyLabel"]</label>
                            <div class="sp-llm-key">
                                <input class="sp-reset-input" style="margin:0;" type="password"
                                       placeholder="@prov.KeyHint" @bind="_llmKey" @bind:event="oninput" autocomplete="off" />
                                <button class="sp-send" @onclick="SaveLlmKey" disabled="@string.IsNullOrWhiteSpace(_llmKey)">@L["Llm.SaveButton"]</button>
                                @if (Llm.HasStoredKey(_llmProvider))
                                {
                                    <button class="sp-btn-ghost" @onclick="ClearLlmKey">@L["Llm.RemoveKeyButton"]</button>
                                }
                            </div>
                            <div class="sp-llm-keyhint">
                                @if (Llm.HasStoredKey(_llmProvider)) { <span class="sp-llm-pill ok">@L["Llm.StoredKeyPill"]</span> }
                                else if (Llm.HasKey(_llmProvider)) { <span class="sp-muted">@L["Llm.EnvKeyText"]</span> }
                                else { <span class="sp-muted">@L["Llm.NoKeyText"]</span><a href="@prov.SignupUrl" target="_blank">@L["Llm.GetKeyLink"]</a> }
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(_llmMsg)) { <div class="sp-llm-saved">@_llmMsg</div> }
                    </div>
                </div>

                <div class="sp-modal-actions" style="margin-top:16px;">
                    <button class="sp-btn-ghost" @onclick="CloseLlm">@L["Common.Done"]</button>
                </div>
            </div>
        </div>
    }

    @if (_showSecurity)

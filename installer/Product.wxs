<?xml version="1.0" encoding="UTF-8"?>
<!-- WiX v5 authoring — per-user MSI (no admin), Start-menu shortcut, major-upgrade aware.
     Built by the release workflow:
       wix build installer\Product.wxs -d Version=x.y.z -d PublishDir=publish\win-x64 -arch x64 -o dist\SemanticPortrait-x.y.z-x64.msi -->
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="SemanticPortrait"
           Manufacturer="Earl Cameron"
           Version="$(var.Version)"
           UpgradeCode="69e9177f-19ad-4e69-ba70-4f93cdc1fc5f"
           Scope="perUser"
           Compressed="yes">

    <MajorUpgrade DowngradeErrorMessage="A newer version of SemanticPortrait is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <StandardDirectory Id="LocalAppDataFolder">
      <Directory Id="ProgramsFolder" Name="Programs">
        <Directory Id="INSTALLFOLDER" Name="SemanticPortrait">
          <!-- WiX v5 wildcard harvesting: everything the publish produced, verbatim -->
          <Files Include="$(var.PublishDir)\**" />
        </Directory>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder">
      <Component Id="StartMenuShortcut" Guid="7a2a6a10-53c1-4b1e-9a67-0d9a2b6f3c11">
        <Shortcut Id="AppShortcut"
                  Name="SemanticPortrait"
                  Target="[INSTALLFOLDER]SemanticPortrait.App.exe"
                  WorkingDirectory="INSTALLFOLDER" />
        <RemoveFolder Id="CleanupShortcut" On="uninstall" />
        <RegistryValue Root="HKCU" Key="Software\SemanticPortrait" Name="installed"
                       Type="integer" Value="1" KeyPath="yes" />
      </Component>
    </StandardDirectory>
  </Package>
</Wix>
